        }
      }
    },
    "Beads Pro": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Beads Pro"
          }
        }
      }
    },
    "Beads stores your practice and journal entries only in your own iCloud account — nothing is shared with anyone unless you choose to share a Ripple Card.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Beads 只会把你的练习记录和日记保存在你自己的 iCloud 账户里——除非你主动分享心语卡片，否则不会有任何人看到。"
          }
        }
      }
    },
    "Breathe in…": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "吸气…"
          }
        }
      }
    },
    "Breathe out…": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "呼气…"
